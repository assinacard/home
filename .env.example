# Token secreto da integração interna do Notion.
# Nunca coloque esse valor dentro do HTML, CSS ou JS público.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID da data source do Notion, não apenas o database/container ID.
# No Notion atual, o recomendado é usar data_source_id para criar linhas/páginas.
NOTION_DATA_SOURCE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: domínio autorizado da sua página em produção.
# Exemplo: https://www.assinacard.com.br
ALLOWED_ORIGIN=*

# Opcional: use se os nomes das colunas no seu Notion forem diferentes.
NOTION_PROP_NOME=Nome
NOTION_PROP_ID=ID AssinaCard
NOTION_PROP_PLANO=Plano
NOTION_PROP_EMAIL=E-mail
NOTION_PROP_WHATSAPP=WhatsApp
NOTION_PROP_CHECKOUT=Checkout
NOTION_PROP_ORIGEM=Origem
NOTION_PROP_CRIADO_EM=Criado em
NOTION_PROP_STATUS=Status
